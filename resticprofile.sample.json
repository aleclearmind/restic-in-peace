{
    "global": {
        "restic-binary": "/home/<user>/.local/bin/restic-in-peace"
    },
    "common": {
        "added-size-limit": "5000000000",
        "skip-on-battery": true,
        "wifi-whitelist": ["whitelisted-network"],
        "wifi-blacklist": ["blacklisted-network"],
        "monitor-url": ["https://<monitor_host>/restic"],
        "desktop-notifications": true,
        "backup": {
            "run-before": [],
            "run-after": [],
            "check-after": true
        },
        "check": {},
        "password-file": "~/.config/backup/restic_password",
        "repository": "<repo_path_or_url>",
        "retention": {
            "after-backup": true,
            "keep-daily": "7",
            "keep-weekly": "4",
            "keep-monthly": "6",
            "keep-yearly": "1",
            "prune": true
        }
    },
    "profile_1": {
        "inherit": "common",
        "backup": {
            "source": ["/home/<user>"],
            "tag": "profile_1_tag"
        }
    }
}
